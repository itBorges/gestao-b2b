# Impede que o Lombok procure configs em diretórios acima (bom para monorepos)
config.stopBittracing = true
# Adiciona @Generated nos métodos, ajudando ferramentas de cobertura de testes
# (ex: JaCoCo) a ignorar código gerado pelo Lombok
lombok.addLombokGeneratedAnnotation = true
# Evita erro se @Builder for usado junto de outras anotações que geram construtor
lombok.builder.className = Builder
# Impede que @Data gere um equals/hashCode que quebra em entidades JPA
lombok.equalsAndHashCode.callSuper = warn
# Deixa o log mais limpo, sem sugestões de "copiar" campos
lombok.copyableAnnotations += org.springframework.beans.factory.annotation.Autowired